# ===========================================
# Firebase Configuration - UAT Environment
# ===========================================
# Get these values from Firebase Console:
# https://console.firebase.google.com/project/YOUR_PROJECT/settings/general/

NEXT_PUBLIC_FIREBASE_UAT_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_UAT_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_UAT_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_UAT_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_UAT_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_UAT_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_UAT_MEASUREMENT_ID=your_measurement_id
NEXT_PUBLIC_FIREBASE_UAT_VAPID_KEY=your_vapid_key

# ===========================================
# Firebase Configuration - PROD Environment
# ===========================================
# Copy UAT values for development, use PROD values for production

NEXT_PUBLIC_FIREBASE_PROD_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_PROD_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROD_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_PROD_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_PROD_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_PROD_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_PROD_MEASUREMENT_ID=your_measurement_id
NEXT_PUBLIC_FIREBASE_PROD_VAPID_KEY=your_vapid_key

# ===========================================
# Firebase Admin SDK (Server-side)
# ===========================================
# Generate private key from: https://console.firebase.google.com/project/YOUR_PROJECT/settings/serviceaccounts/adminsdk
# Convert to base64: cat service-account.json | base64 -w 0
FIREBASE_ADMIN_SDK_BASE64=your_base64_encoded_service_account_json

# ===========================================
# App Configuration
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# AI Provider Configuration
# ===========================================
# Default provider: 'gemini' (see src/lib/firebase/config/environments.ts)

# Gemini API Key (if using Gemini provider)
GEMINI_API_KEY=your_gemini_api_key

# KieAI API Key (if using KieAI provider)
KIEAI_API_KEY=your_kieai_api_key
